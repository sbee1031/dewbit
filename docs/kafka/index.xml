&lt;div&gt;&lt;pre&gt;&lt;code&gt;kafka-configs.sh --bootstrap-server &amp;lt;bootstrap-server&amp;gt; --alter --entity-type topics --entity-name &amp;lt;topic&amp;gt; --add-config retention.ms=&amp;lt;retention&amp;gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;div class="hextra-code-copy-btn-container hx:opacity-0 hx:transition hx:group-hover/code:opacity-100 hx:flex hx:gap-1 hx:absolute hx:m-[11px] hx:right-0 hx:top-0"&gt;
