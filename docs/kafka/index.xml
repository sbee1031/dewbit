kafka-configs --bootstrap-server &amp;lt;bootstrap-server&amp;gt; --describe --entity-type &amp;lt;topics/brokers&amp;gt; --entity-name &amp;lt;topic/broker&amp;gt;
# 기본값 포함 모든 설정 확인
kafka-configs --bootstrap-server &amp;lt;bootstrap-server&amp;gt; --describe --entity-type topics --all
kafka-configs --bootstrap-server &amp;lt;bootstrap-server&amp;gt; --describe --entity-type topics --entity-name &amp;lt;topic/broker&amp;gt; --all&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;div class="hextra-code-copy-btn-container hx:opacity-0 hx:transition hx:group-hover/code:opacity-100 hx:flex hx:gap-1 hx:absolute hx:m-[11px] hx:right-0 hx:top-0"&gt;
