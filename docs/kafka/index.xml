&lt;h2&gt;kafka-reassign-partition.sh&lt;span class="hx:absolute hx:-mt-20" id="kafka-reassign-partitionsh"&gt;&lt;/span&gt;
&lt;a href="#kafka-reassign-partitionsh" class="subheading-anchor" aria-label="Permalink to this section"&gt;&lt;/a&gt;&lt;/h2&gt;&lt;p&gt;파티션 리더 변경&lt;/p&gt;
&lt;div class="hextra-code-block hx:relative hx:mt-6 hx:first:mt-0 hx:group/code"&gt;
&lt;div&gt;&lt;pre&gt;&lt;code&gt;# json (__consumer_offsets 토픽 파티션 2번의 리더 변경)
{
&amp;#34;version&amp;#34;: 1,
&amp;#34;partitions&amp;#34;: [
{
&amp;#34;topic&amp;#34;: &amp;#34;__consumer_offsets&amp;#34;,
&amp;#34;partition&amp;#34;: 2,
&amp;#34;replicas&amp;#34;: [1, 0, 2],
&amp;#34;log_dirs&amp;#34;: [&amp;#34;any&amp;#34;, &amp;#34;any&amp;#34;, &amp;#34;any&amp;#34;]
}
]
}
kafka-reassign-partition.sh --bootstrap-server &amp;lt;bootstrap-server&amp;gt; --execute --reassignment-json-file &amp;lt;file&amp;gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;div class="hextra-code-copy-btn-container hx:opacity-0 hx:transition hx:group-hover/code:opacity-100 hx:flex hx:gap-1 hx:absolute hx:m-[11px] hx:right-0 hx:top-0"&gt;
